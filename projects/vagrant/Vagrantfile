Vagrant.configure("2") do |config|
  config.vm.box = "ubuntu/focal64"

  config.vm.provider "virtualbox" do |vb|
    vb.memory = 1024
    vb.cpus = 1
  end

  config.vm.define "dbvm" do |db|
    db.vm.hostname = "dbvm"
    db.vm.network "private_network", ip: "192.168.56.10"
    db.vm.synced_folder "./shared", "/shared", create: true

    db.vm.provision "shell", inline: <<-SHELL
      apt-get update
      apt-get install -y sqlite3

      if [ ! -f /shared/Donotshare ]; then
        dd if=/dev/zero of=/shared/Donotshare bs=1M count=10
      fi

      sqlite3 /home/vagrant/newdatabage.db <<'SQL'
      CREATE TABLE IF NOT EXISTS t1 (id INTEGER PRIMARY KEY, name TEXT);
      CREATE TABLE IF NOT EXISTS t2 (id INTEGER PRIMARY KEY, name TEXT);
      CREATE TABLE IF NOT EXISTS t3 (id INTEGER PRIMARY KEY, name TEXT);
      CREATE TABLE IF NOT EXISTS t4 (id INTEGER PRIMARY KEY, name TEXT);
      SQL
    SHELL
  end

  config.vm.define "nodevm" do |node|
    node.vm.hostname = "nodevm"
    node.vm.network "private_network", ip: "192.168.56.11"
    node.vm.network "forwarded_port", guest: 3000, host: 8080
    node.vm.synced_folder "./shared", "/shared", create: true

    node.vm.provision "shell", inline: <<-SHELL
      apt-get update
      apt-get install -y nodejs npm sqlite3

      cat >/home/vagrant/app.js <<'JS'
      const http = require("http");
      const fs = require("fs");

      const server = http.createServer((req, res) => {
        const fileExists = fs.existsSync("/shared/Donotshare");
        const message = fileExists
          ? "Success: Node app is running and Donotshare is available."
          : "Node app is running, but Donotshare was not found.";

        res.writeHead(200, { "Content-Type": "text/plain" });
        res.end(message);
      });

      server.listen(3000, "0.0.0.0", () => {
        console.log("Server listening on port 3000");
      });
      JS

      chown vagrant:vagrant /home/vagrant/app.js
    SHELL

    node.vm.provision "shell", run: "always", inline: <<-SHELL
      pkill -f "node /home/vagrant/app.js" || true
      nohup node /home/vagrant/app.js >/home/vagrant/node-app.log 2>&1 &
    SHELL
  end
end